# Prebuilt native binaries — populated per release by the private core
# repo's publish workflow, not checked in as source. Grab them from this
# repo's GitHub Releases instead of building locally, unless you're
# iterating on the wrapper source itself.
python/unirt/lib/
android/prebuilt/
ios/UniRT.xcframework/

# iOS example app: xcodegen regenerates the .xcodeproj from project.yml,
# and test models are downloaded per its README, not checked in
examples/ios/UniRTChatExample/UniRTChatExample.xcodeproj/
examples/ios/UniRTChatExample/UniRTChatExample/Info.plist
examples/ios/UniRTChatExample/Resources/*.gguf
**/xcuserdata/

# Python build artifacts
build/
dist/
*.egg-info/
__pycache__/
**/__pycache__/
*.py[cod]
.pytest_cache/
.venv/

